{
  "expo": {
    "name": "Mizan",
    "slug": "mizan-app",
    "version": "1.1.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "scheme": "mizan",
    "userInterfaceStyle": "light",
    "platforms": ["ios", "android"],
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mizan.app",
      "buildNumber": "4",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "عشان نسجل موقع المصروف",
        "NSLocationAlwaysUsageDescription": "عشان التذكيرات بناءً على موقعك",
        "NSCalendarsUsageDescription": "عشان نضيف مهامك للتقويم",
        "NSContactsUsageDescription": "لربط الديون بجهات الاتصال",
        "NSFaceIDUsageDescription": "لحماية التطبيق بالبصمة"
      }
    },
    "android": {
      "package": "com.mizan.app",
      "versionCode": 4,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#FFFFFF"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.READ_CONTACTS",
        "android.permission.USE_BIOMETRIC"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      ["expo-notifications", { "color": "#38BDF8" }],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Mizan يحتاج موقعك للتذكيرات الذكية"
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "Mizan يحتاج إذن جهات الاتصال لربط الديون"
        }
      ],
      "expo-sharing",
      "expo-document-picker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6a297929-2aed-46d2-b516-dc1acfa5ab0e"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/6a297929-2aed-46d2-b516-dc1acfa5ab0e"
    }
  }
}
